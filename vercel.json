{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Permissions-Policy", "value": "document-domain=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://vitals.vercel-insights.com; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self';" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/assets/$1"
    },
    {
      "src": "/css/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/js/$1"
    },
    {
      "src": "/fonts/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/fonts/$1"
    },
    {
      "src": "/qrcode.png",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/qrcode.png"
    },
    {
      "src": "/og-image.png",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/og-image.png"
    },
    {
      "src": "/og-female.png",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/og-female.png"
    },
    {
      "src": "/og-male.png",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/og-male.png"
    },
    {
      "src": "/*.png",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/$1.png"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" }
    },
    {
      "src": "/female.html",
      "dest": "/female.html"
    },
    {
      "src": "/male.html", 
      "dest": "/male.html"
    },
    {
      "src": "/s.html",
      "dest": "/s.html"
    },
    {
      "src": "/lgbt.html",
      "dest": "/lgbt.html"
    },
    {
      "src": "/member.html",
      "dest": "/member.html"
    },
    {
      "src": "/share.html",
      "dest": "/share.html"
    },
    {
      "src": "/sangok.html",
      "dest": "/sangok.html"
    },
    {
      "src": "/message.html",
      "dest": "/message.html"
    },
    {
      "src": "/gallery.html",
      "dest": "/gallery.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "/404.html"
    }
  ]
}
